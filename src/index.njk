---
layout: base.njk
---

<!-- Hero -->
<div class="hero">
  <div class="container">
    <h1>{{ site.hero.name }}</h1>
    <p lang="en">{{ site.hero.tagline.en }}</p>
    <p lang="zh">{{ site.hero.tagline.zh }}</p>
  </div>
</div>

<!-- About -->
<section id="about">
  <div class="container">
    <h2 class="section-title" lang="en">{{ site.aboutTitle.en }}</h2>
    <h2 class="section-title" lang="zh">{{ site.aboutTitle.zh }}</h2>
    <div class="about-text">
      {% for para in site.aboutParagraphs %}
      <p lang="en">{{ para.en }}</p>
      <p lang="zh">{{ para.zh }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Projects -->
<section id="projects">
  <div class="container">
    <h2 class="section-title" lang="en">{{ site.projectsTitle.en }}</h2>
    <h2 class="section-title" lang="zh">{{ site.projectsTitle.zh }}</h2>
    <div class="projects-grid">
      {% for proj in collections.projects %}
      <div class="project-card">
        <h3><a href="#" lang="en">{{ proj.data.title_en }}</a><a href="#" lang="zh">{{ proj.data.title_zh }}</a></h3>
        <p lang="en">{{ proj.data.excerpt_en }}</p>
        <p lang="zh">{{ proj.data.excerpt_zh }}</p>
        <div class="project-tags">
          {% for tag in proj.data.tags %}
          {% if tag !== 'projects' and tag !== 'posts' %}
          <span>{{ tag }}</span>
          {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Blog -->
<section id="blog">
  <div class="container">
    <h2 class="section-title" lang="en">{{ site.blogTitle.en }}</h2>
    <h2 class="section-title" lang="zh">{{ site.blogTitle.zh }}</h2>
    <ul class="blog-list">
      <li class="blog-item">
        <h3><a href="/time-class.html">⏰ 时间管理小课堂</a></h3>
        <div class="blog-date">2026-07-03</div>
        <p class="blog-excerpt">交互式演示文稿：时间管理方法与技巧，帮助高效规划每一天。</p>
      </li>
      <li class="blog-item">
        <h3><a href="/modern-ai-architecture.html">🤖 现代AI应用架构 · 教学演示</a></h3>
        <div class="blog-date">2026-07-04</div>
        <p class="blog-excerpt">深入讲解现代AI应用的分层架构设计，从推理引擎到AI代理的完整技术栈。</p>
      </li>
      {% for post in collections.posts %}
      <li class="blog-item">
        <h3><a href="#" lang="en">{{ post.data.title_en }}</a><a href="#" lang="zh">{{ post.data.title_zh }}</a></h3>
        <div class="blog-date">{{ post.data.date | formatDate }}</div>
        <p class="blog-excerpt" lang="en">{{ post.data.excerpt_en }}</p>
        <p class="blog-excerpt" lang="zh">{{ post.data.excerpt_zh }}</p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
